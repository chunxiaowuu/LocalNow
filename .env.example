# docker compose 读取本文件做 ${VAR} 替换。复制为 .env 并填入真实值。
# LLM 提供方：anthropic | openai | deepseek | ollama | gemini
LLM_PROVIDER=gemini

# 按所选 provider 填对应密钥即可
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# 高德地图（场所/餐厅召回，必填才能用真实数据，否则走本地 mock）
AMAP_API_KEY=

# 可观测性（可选）
LANGSMITH_API_KEY=

# 前端访问后端的地址（浏览器可达；本地保持默认即可）
NEXT_PUBLIC_API_URL=http://localhost:8000
