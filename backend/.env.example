# LLM Provider 选择（切换此行即可换模型）
LLM_PROVIDER=anthropic  # anthropic | openai | deepseek | ollama

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# 可观测性（可选，不填则跳过）
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=localnow

# Agent 行为
MAX_REPLAN_COUNT=2
AVAILABILITY_TIMEOUT_S=5.0
MAX_CANDIDATE_PLANS=2
